generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CITIZEN
  GOVERNMENT_OFFICER
  ADMIN
}

enum ApprovalStatus {
  ACTIVE
  PENDING_APPROVAL
  SUSPENDED
}

enum IssueType {
  POTHOLE
  BROKEN_ROAD
  SIDEWALK_DAMAGE
  OVERFLOWING_BIN
  GARBAGE
  BROKEN_STREET_LIGHT
  TRAFFIC_LIGHT_DAMAGE
  WATER_LEAKAGE
  TRAFFIC_SIGN_DAMAGE
  CONSTRUCTION_HAZARD
  ROAD_CRACK
  OTHER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReportStatus {
  PENDING
  ACCEPTED
  UNDER_REVIEW
  WORK_STARTED
  IN_PROGRESS
  DELAYED
  COMPLETED
  CLOSED
  RESOLVED
  REJECTED
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  password       String
  role           UserRole       @default(CITIZEN)
  approvalStatus ApprovalStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  reports             Report[]
  governmentActions   GovernmentAction[]
  announcements       Announcement[]
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
}

model Report {
  id          String       @id @default(cuid())
  userId      String
  issueType   IssueType
  severity    Severity
  description String?
  status      ReportStatus @default(PENDING)
  latitude    Float
  longitude   Float
  address     String?
  imageUrl    String
  aiSummary   String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  governmentActions GovernmentAction[]
  notifications     Notification[]

  @@index([userId])
  @@index([status])
  @@index([severity])
  @@index([issueType])
  @@index([createdAt])
}

model GovernmentAction {
  id                  String    @id @default(cuid())
  reportId            String
  officerId           String
  assignedTeam        String?
  actionTaken         String
  progress            Int?
  estimatedCompletion DateTime?
  delayReason         String?
  isPublic            Boolean   @default(true)
  createdAt           DateTime  @default(now())

  report  Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  officer User   @relation(fields: [officerId], references: [id])

  @@index([reportId])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  officerId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  officer User @relation(fields: [officerId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  reportId  String?
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report? @relation(fields: [reportId], references: [id], onDelete: SetNull)

  @@index([userId, read])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}
